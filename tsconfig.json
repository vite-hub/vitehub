{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "files": [],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    ".nuxt",
    ".output",
    ".data",
    "packages/*/dist",
    "docs/.nuxt",
    "docs/.output",
    "docs/.data"
  ]
}
