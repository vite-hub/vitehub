{
  "name": "@vitehub/blob",
  "version": "0.0.0",
  "description": "Blob storage primitives and Nitro/Nuxt integration for ViteHub.",
  "author": "onmax <maximogarciamtnez@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/vite-hub/vitehub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vite-hub/vitehub.git",
    "directory": "packages/blob"
  },
  "bugs": "https://github.com/vite-hub/vitehub/issues",
  "keywords": [
    "vitehub",
    "vite",
    "nitro",
    "nuxt",
    "blob",
    "cloudflare",
    "vercel"
  ],
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./nitro": "./dist/nitro.js",
    "./nuxt": "./dist/nuxt.js",
    "./runtime/cloudflare-r2": "./dist/runtime/cloudflare-r2.js",
    "./runtime/nitro-plugin": "./dist/runtime/nitro-plugin.js",
    "./runtime/vercel-blob": "./dist/runtime/vercel-blob.js",
    "./virtual": "./dist/virtual.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "pnpm build && tsx ./test/e2e.ts"
  },
  "dependencies": {
    "@nuxt/kit": "catalog:nuxt-nightly",
    "defu": "catalog:",
    "exsolve": "catalog:",
    "h3": "catalog:",
    "mime": "catalog:"
  },
  "peerDependencies": {
    "@vercel/blob": "^2.3.3",
    "nitro": "^3.0.0-0",
    "vite": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@vercel/blob": {
      "optional": true
    },
    "nitro": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@nuxt/schema": "catalog:nuxt-nightly",
    "@vercel/blob": "catalog:",
    "get-port-please": "catalog:",
    "miniflare": "catalog:",
    "nitro": "catalog:",
    "ofetch": "catalog:",
    "publint": "^0.3.15",
    "tinyexec": "catalog:",
    "tsdown": "^0.21.8",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "vitehub": {
    "ci": {
      "e2e": {
        "frameworks": [
          "nitro",
          "nuxt",
          "vite"
        ],
        "providers": [
          "cloudflare",
          "vercel"
        ],
        "live": {
          "appPrefix": "vitehub-blob",
          "enabled": true,
          "frameworks": [
            "nitro",
            "nuxt",
            "vite"
          ],
          "providers": [
            "cloudflare",
            "vercel"
          ],
          "cloudflare": {
            "createR2Bucket": true,
            "strategy": "template",
            "wranglerTemplate": "playground/_shared/wrangler.template.jsonc"
          },
          "vercel": {
            "deployEnv": {
              "blobReadWriteToken": true
            }
          }
        }
      }
    }
  }
}
