{
  "label": "Blob",
  "docsPath": "blob",
  "icon": "i-lucide-files",
  "order": 2,
  "providers": [
    {
      "id": "cloudflare-r2",
      "label": "Cloudflare",
      "icon": "i-simple-icons-cloudflare",
      "configOverride": "  blob: {\n    driver: 'cloudflare-r2',\n    binding: 'BLOB',\n    bucketName: '<bucket-name>',\n  },"
    },
    {
      "id": "vercel-blob",
      "label": "Vercel",
      "icon": "i-simple-icons-vercel",
      "darkInvert": true,
      "configOverride": "  blob: {\n    driver: 'vercel-blob',\n  },",
      "envOverride": "BLOB_READ_WRITE_TOKEN=<blob-read-write-token>"
    }
  ],
  "frameworks": {
    "vite": {
      "modes": {
        "dev": {
          "phases": {
            "configure": "vite.config.ts",
            "run": "src/server.ts"
          },
          "supplementalFiles": [
            "package.json"
          ]
        },
        "build": {
          "phases": {
            "configure": "vite.config.ts",
            "run": "src/server.ts"
          },
          "supplementalFiles": [
            "package.json"
          ]
        }
      }
    }
  }
}
