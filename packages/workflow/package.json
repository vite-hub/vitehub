{
  "name": "@vitehub/workflow",
  "version": "0.0.0",
  "description": "Workflow primitives and Vite integration for ViteHub.",
  "author": "onmax <maximogarciamtnez@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/vite-hub/vitehub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vite-hub/vitehub.git",
    "directory": "packages/workflow"
  },
  "bugs": "https://github.com/vite-hub/vitehub/issues",
  "keywords": [
    "vitehub",
    "vite",
    "nitro",
    "workflow",
    "cloudflare",
    "vercel"
  ],
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./nitro": "./dist/nitro.js",
    "./runtime/cloudflare-shared": "./dist/runtime/cloudflare-shared.js",
    "./runtime/cloudflare-vite": "./dist/runtime/cloudflare-vite.js",
    "./runtime/nitro-plugin": "./dist/runtime/nitro-plugin.js",
    "./runtime/state": "./dist/runtime/state.js",
    "./runtime/vercel-vite": "./dist/runtime/vercel-vite.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "test": "pnpm --filter @vitehub/workflow build && vitest run",
    "test:e2e": "node ./test/e2e-live.mjs"
  },
  "dependencies": {
    "@vercel/functions": "catalog:",
    "defu": "catalog:",
    "esbuild": "catalog:",
    "h3": "catalog:",
    "pathe": "catalog:"
  },
  "peerDependencies": {
    "nitro": "^3.0.0-0",
    "vite": "^8.0.0",
    "workflow": "^4.2.4"
  },
  "peerDependenciesMeta": {
    "nitro": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "workflow": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitehub/internal": "workspace:*",
    "nitro": "catalog:",
    "ofetch": "catalog:",
    "publint": "^0.3.15",
    "tsdown": "^0.21.8",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
