{
  "name": "@vitehub/queue",
  "version": "0.0.0",
  "description": "Queue primitives and Vite/Nitro deployment integration for ViteHub.",
  "author": "onmax <maximogarciamtnez@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/vite-hub/vitehub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vite-hub/vitehub.git",
    "directory": "packages/queue"
  },
  "bugs": "https://github.com/vite-hub/vitehub/issues",
  "keywords": [
    "vitehub",
    "vite",
    "nitro",
    "h3",
    "queue",
    "cloudflare",
    "vercel"
  ],
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./nitro": "./dist/nitro.js",
    "./runtime/cloudflare-vite": "./dist/runtime/cloudflare-vite.js",
    "./runtime/hosted": "./dist/runtime/hosted.js",
    "./runtime/nitro-plugin": "./dist/runtime/nitro-plugin.js",
    "./runtime/state": "./dist/runtime/state.js",
    "./runtime/vercel-vite": "./dist/runtime/vercel-vite.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@vercel/functions": "catalog:",
    "defu": "catalog:",
    "esbuild": "^0.27.7",
    "exsolve": "catalog:",
    "h3": "catalog:",
    "pathe": "catalog:"
  },
  "peerDependencies": {
    "@vercel/queue": "^0.0.0-alpha.23",
    "nitro": "^3.0.0-0",
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@vercel/queue": {
      "optional": true
    },
    "nitro": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitehub/internal": "workspace:*",
    "publint": "^0.3.15",
    "tsdown": "^0.21.8",
    "typescript": "catalog:",
    "nitro": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
