{
  "name": "@vitehub/queue",
  "version": "0.0.0",
  "description": "Queue primitives and Nitro/Nuxt integration for ViteHub.",
  "author": "onmax <maximogarciamtnez@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/vite-hub/vitehub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vite-hub/vitehub.git",
    "directory": "packages/queue"
  },
  "bugs": "https://github.com/vite-hub/vitehub/issues",
  "keywords": [
    "vitehub",
    "vite",
    "nitro",
    "nuxt",
    "queue",
    "cloudflare",
    "vercel"
  ],
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "imports": {
    "#vitehub-queue-registry": {
      "types": "./dist/runtime/empty-registry.d.ts",
      "default": "./dist/runtime/empty-registry.js"
    },
    "#vitehub-queue-vercel-provider": {
      "types": "./dist/runtime/vercel-provider.d.ts",
      "default": "./dist/runtime/vercel-provider.js"
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./nitro": "./dist/nitro.js",
    "./nuxt": "./dist/nuxt.js",
    "./runtime/empty-registry": "./dist/runtime/empty-registry.js",
    "./runtime/hosted": "./dist/runtime/hosted.js",
    "./runtime/nitro-plugin": "./dist/runtime/nitro-plugin.js",
    "./runtime/vercel-provider": "./dist/runtime/vercel-provider.js",
    "./runtime/vercel-provider-stub": "./dist/runtime/vercel-provider-stub.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "pnpm build && tsx ./test/e2e.ts"
  },
  "vitehub": {
    "ci": {
      "e2e": {
        "frameworks": [
          "nitro",
          "nuxt",
          "vite-plugin"
        ],
        "providers": [
          "cloudflare",
          "vercel"
        ],
        "live": {
          "appPrefix": "vitehub-queue-playground",
          "enabled": true,
          "frameworks": [
            "nitro",
            "nuxt",
            "vite-plugin"
          ],
          "providers": [
            "cloudflare",
            "vercel"
          ],
          "cloudflare": {
            "createQueues": true,
            "strategy": "generated"
          }
        }
      }
    }
  },
  "dependencies": {
    "@nuxt/kit": "catalog:nuxt-nightly",
    "defu": "catalog:",
    "exsolve": "catalog:",
    "h3": "catalog:"
  },
  "peerDependencies": {
    "@vercel/queue": "^0.1.3",
    "nitro": "^3.0.0-0",
    "vite": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@vercel/queue": {
      "optional": true
    },
    "nitro": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.1",
    "@nuxt/schema": "catalog:nuxt-nightly",
    "@vercel/queue": "^0.1.3",
    "@vitehub/internal-ci": "workspace:*",
    "get-port-please": "catalog:",
    "miniflare": "catalog:",
    "nitro": "catalog:",
    "ofetch": "catalog:",
    "publint": "^0.3.15",
    "tinyexec": "catalog:",
    "tsdown": "^0.21.8",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
