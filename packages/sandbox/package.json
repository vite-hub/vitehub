{
  "name": "@vitehub/sandbox",
  "version": "0.0.0",
  "description": "Sandbox execution primitives and Nitro/Nuxt integration for ViteHub.",
  "author": "onmax <maximogarciamtnez@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/vite-hub/vitehub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vite-hub/vitehub.git",
    "directory": "packages/sandbox"
  },
  "bugs": "https://github.com/vite-hub/vitehub/issues",
  "keywords": [
    "vitehub",
    "vite",
    "nitro",
    "nuxt",
    "sandbox",
    "cloudflare",
    "vercel"
  ],
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "imports": {
    "#vitehub-sandbox-provider-loader": {
      "types": "./dist/runtime/provider-loader.d.ts",
      "default": "./dist/runtime/provider-loader.js"
    },
    "#vitehub-sandbox-registry": {
      "types": "./dist/runtime/empty-registry.d.ts",
      "default": "./dist/runtime/empty-registry.js"
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./nitro": "./dist/nitro.js",
    "./nuxt": "./dist/nuxt.js",
    "./runtime/empty-registry": "./dist/runtime/empty-registry.js",
    "./runtime/nitro-plugin": "./dist/runtime/nitro-plugin.js",
    "./runtime/provider-loader": "./dist/runtime/provider-loader.js",
    "./runtime/providers/cloudflare": "./dist/runtime/providers/cloudflare.js",
    "./runtime/providers/vercel": "./dist/runtime/providers/vercel.js",
    "./sandbox/providers/cloudflare": "./dist/sandbox/providers/cloudflare.js",
    "./sandbox/providers/vercel": "./dist/sandbox/providers/vercel.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "tsx ./test/e2e.ts"
  },
  "dependencies": {
    "@nuxt/kit": "catalog:",
    "esbuild": "catalog:",
    "h3": "catalog:",
    "local-pkg": "catalog:",
    "mlly": "catalog:",
    "pathe": "catalog:",
    "pkg-types": "catalog:",
    "rollup": "catalog:",
    "scule": "catalog:",
    "ufo": "catalog:",
    "unctx": "catalog:",
    "unimport": "catalog:"
  },
  "peerDependencies": {
    "@cloudflare/sandbox": "catalog:",
    "@vercel/sandbox": "catalog:",
    "nitro": "^3.0.0-0",
    "vite": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/sandbox": {
      "optional": true
    },
    "@vercel/sandbox": {
      "optional": true
    },
    "nitro": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/sandbox": "catalog:",
    "@nuxt/schema": "catalog:",
    "@vercel/sandbox": "catalog:",
    "get-port-please": "catalog:",
    "miniflare": "catalog:",
    "nitro": "catalog:",
    "ofetch": "catalog:",
    "publint": "^0.3.15",
    "tinyexec": "catalog:",
    "tsdown": "^0.21.8",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
