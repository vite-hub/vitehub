{
  "name": "@vitehub/kv",
  "version": "0.0.0",
  "description": "Key-value storage primitives and Nitro/Nuxt integration for ViteHub.",
  "author": "onmax <maximogarciamtnez@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/vite-hub/vitehub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vite-hub/vitehub.git",
    "directory": "packages/kv"
  },
  "bugs": "https://github.com/vite-hub/vitehub/issues",
  "keywords": [
    "vitehub",
    "vite",
    "nitro",
    "nuxt",
    "kv",
    "cloudflare",
    "vercel"
  ],
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./nitro": "./dist/nitro.js",
    "./nuxt": "./dist/nuxt.js",
    "./runtime/nitro-plugin": "./dist/runtime/nitro-plugin.js",
    "./runtime/nitropack-plugin": "./dist/runtime/nitropack-plugin.js",
    "./runtime/nitropack-storage": "./dist/runtime/nitropack-storage.js",
    "./vite": "./dist/vite.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsdown --tsconfig tsconfig.build.json",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "tsx ./test/e2e.ts"
  },
  "dependencies": {
    "@nuxt/kit": "catalog:",
    "defu": "catalog:",
    "exsolve": "catalog:",
    "unstorage": "catalog:"
  },
  "peerDependencies": {
    "@upstash/redis": "^1.37.0",
    "nitropack": "^2.13.3",
    "nitro": "^3.0.0-0",
    "vite": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@upstash/redis": {
      "optional": true
    },
    "nitro": {
      "optional": true
    },
    "nitropack": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/schema": "catalog:",
    "@upstash/redis": "catalog:",
    "get-port-please": "catalog:",
    "miniflare": "catalog:",
    "nitro": "catalog:",
    "nitropack": "^2.13.3",
    "ofetch": "catalog:",
    "publint": "^0.3.15",
    "tinyexec": "catalog:",
    "tsdown": "^0.21.8",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
