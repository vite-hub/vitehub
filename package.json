{
  "name": "vitehub-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "ViteHub monorepo workspace.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "lint": "pnpm exec oxlint . --ignore-path .gitignore",
    "typecheck": "pnpm --dir docs typecheck && pnpm -r --filter './packages/*' --if-present run typecheck",
    "test": "pnpm -r --filter './packages/*' --if-present run test",
    "build": "pnpm -r --filter './packages/*' --if-present run build",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
