{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": false,
    "noImplicitAny": false
  },
  "include": [
    ".nuxt/content/types.d.ts",
    ".nuxt/types/**/*.d.ts",
    ".nuxt/imports.d.ts",
    "app/**/*.ts",
    "app/**/*.vue",
    "modules/**/*.ts",
    "modules/**/*.vue",
    "types/**/*.d.ts",
    "content.config.ts",
    "nuxt.config.ts",
    ".generated/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    ".output",
    "../node_modules/.pnpm/docus@*/node_modules/docus/modules/assistant/runtime/server/api/search.ts"
  ]
}
